<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="Theme.MVVMAPP" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorSecondaryVariant">@color/blue_secondary_dark</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/accent_green</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/background_surface</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Card view -->
        <item name="cardBackgroundColor">@color/background_card</item>
    </style>
    
    <!-- Theme for AppBar -->
    <style name="Theme.MVVMAPP.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_dark</item>
        <item name="colorAccent">@color/accent_blue</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorSecondaryVariant">@color/blue_secondary_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/accent_green</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/background_surface</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Card view -->
        <item name="cardBackgroundColor">@color/background_card</item>
    </style>
    
    <!-- Theme for Popup -->
    <style name="Theme.MVVMAPP.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" >
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_dark</item>
        <item name="colorAccent">@color/accent_blue</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorSecondaryVariant">@color/blue_secondary_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/accent_green</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/background_surface</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Card view -->
        <item name="cardBackgroundColor">@color/background_card</item>
    </style>

</resources>